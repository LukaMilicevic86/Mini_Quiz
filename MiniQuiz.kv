
<FirstScreen>
    BoxLayout:
        orientation: 'vertical'
        size: root.width, root.height
        Label:
            text: "Which of these are Marvel heroes?"
        GridLayout:
            cols: 2

            Label:
                text: "Conan"
            CheckBox:
                id: conan1
                on_active: root.chckbox.click1(self, self.active, "Conan")
            
            Label:
                text: "Thor"
            CheckBox:
                id: thor1
                on_active: root.chckbox.click1(self, self.active, "Thor")
            
            Label:
                text: "Hulk"
            CheckBox:
                id: hulk1
                on_active: root.chckbox.click1(self, self.active, "Hulk")
            
            Label:
                text: "Superman"
            CheckBox:
                id: superman1
                on_active: root.chckbox.click1(self, self.active, "Superman")
        
        Label:
            text:''
            id: display1
        
        Button:
            text: 'Next'
            on_press: root.next1()

<SecondScreen>
    BoxLayout:
        orientation: 'vertical'
        size: root.width, root.height
        Label:
            text: "Which of these are DC heroes?"
        GridLayout:
            cols: 2

            Label:
                text: "Batman"
            CheckBox:
                id: batman2
                on_active: root.chckbox.click2(self, self.active, "Batman")
            
            Label:
                text: "Thor"
            CheckBox:
                id: thor2
                on_active: root.chckbox.click2(self, self.active, "Thor")
            
            Label:
                text: "Hulk"
            CheckBox:
                id: hulk2
                on_active: root.chckbox.click2(self, self.active, "Hulk")
            
            Label:
                text: "Superman"
            CheckBox:
                id: superman2
                on_active: root.chckbox.click2(self, self.active, "Superman")
        
        Label:
            text:''
            id: display2
        
        Button:
            text: 'Next'
            on_press: root.next2()


<Results>
    BoxLayout:
        orientation: 'vertical'
        size: root.width, root.height
        Label:
            text: ''
            id: results 
            font_size: root.height*0.05
            size: root.width*0.2, root.height*0.5
            pos: root.width*0.4, root.height*0.5
            on_press: root.restart()

            